---

---

<theme-toggle>
  <button>
    <span class="sr-only">Toggle theme</span>
    <span class="icon sun">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2"></path>
        <path d="M12 20v2"></path>
        <path d="m4.93 4.93 1.41 1.41"></path>
        <path d="m17.66 17.66 1.41 1.41"></path>
        <path d="M2 12h2"></path>
        <path d="M20 12h2"></path>
        <path d="m6.34 17.66-1.41 1.41"></path>
        <path d="m19.07 4.93-1.41 1.41"></path>
      </svg>
    </span>
    <span class="icon moon">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path>
      </svg>
    </span>
  </button>
</theme-toggle>

<style>
  theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  button {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 50%;
    padding: 0;
    margin: 0; /* Reset margin */
    cursor: pointer;
    background-color: transparent;
    color: #333;
    line-height: 1; /* Match others */
    width: 1.5rem; /* Explicit width */
    height: 1.5rem; /* Explicit height */
  }

  .icon {
    display: flex; /* Ensure flex for centering SVG */
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
  }

  .icon svg {
    display: block; /* Remove baseline space */
  }

  .icon.sun {
    display: none;
  }

  .icon.moon {
    display: flex;
  }

  :global(.dark) .icon.sun {
    display: flex;
  }

  :global(.dark) .icon.moon {
    display: none;
  }

  :global(.dark) button {
    color: #ccc;
  }
</style>

<script>
  class ThemeToggle extends HTMLElement {
    constructor() {
      super();

      const button = this.querySelector("button");

      /** Set the theme to dark/light mode. */
      const setTheme = (dark: boolean) => {
        document.documentElement.classList[dark ? "add" : "remove"]("dark");
        button?.setAttribute("aria-pressed", String(dark));
        document.dispatchEvent(
          new CustomEvent("theme-changed", {
            detail: { theme: dark ? "dark" : "light" },
          }),
        );
      };

      // Toggle the theme when a user clicks the button.
      button?.addEventListener("click", () => {
        setTheme(!document.documentElement.classList.contains("dark"));
      });
    }
  }
  customElements.define("theme-toggle", ThemeToggle);
</script>
