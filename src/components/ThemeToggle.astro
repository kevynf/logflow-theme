<theme-toggle><button type="button" aria-label="切换深浅色模式" aria-pressed="false"><svg class="sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg><svg class="moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path></svg></button></theme-toggle>
<style>
  theme-toggle { display:flex; } button { position:relative; display:grid; width:2.25rem; height:2.25rem; padding:0; place-items:center; border:0; border-radius:var(--radius-ui); background:transparent; color:var(--text-secondary); cursor:pointer; transition:background-color .16s ease,color .16s ease; } button:hover { background:var(--background-elevated); color:var(--accent); } svg { position:absolute; width:var(--header-icon-size); height:var(--header-icon-size); fill:none; stroke:currentColor; stroke-width:var(--header-icon-stroke); stroke-linecap:round; stroke-linejoin:round; transition:opacity .16s ease,transform .16s ease; } .sun { opacity:0; transform:rotate(-18deg) scale(.75); } .moon { opacity:1; transform:rotate(0) scale(1); } :global(.dark) .sun { opacity:1; transform:rotate(0) scale(1); } :global(.dark) .moon { opacity:0; transform:rotate(18deg) scale(.75); }
</style>
<script>
  class ThemeToggle extends HTMLElement { connectedCallback() { const button = this.querySelector("button"); if (!button || button.dataset.ready === "true") return; button.dataset.ready = "true"; const sync = () => button.setAttribute("aria-pressed", String(document.documentElement.classList.contains("dark"))); sync(); button.addEventListener("click", () => { document.documentElement.classList.toggle("dark"); sync(); }); } }
  if (!customElements.get("theme-toggle")) customElements.define("theme-toggle", ThemeToggle);
</script>
