---
import { GH_CONTRIBUTE } from "../consts";
import GitHubCalendarWidget from "./GitHubCalendarWidget";
---

<section class="gh-contribute">
  <div class="section-head">
    <h2><a href={GH_CONTRIBUTE.profileUrl} target="_blank" rel="noopener noreferrer">{GH_CONTRIBUTE.title}</a></h2>
    <p>{GH_CONTRIBUTE.description}</p>
  </div>
  <GitHubCalendarWidget
    client:visible
    username={GH_CONTRIBUTE.username}
    errorMessage={GH_CONTRIBUTE.errorMessage}
  />
</section>

<style>
  .gh-contribute {
    margin-top: 0;
    width: 100%;
    min-width: 0;
  }
  :global(.gh-contribute .gh-calendar-viewport) {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-x: contain;
    padding-bottom: 0.25rem;
    scrollbar-width: thin;
    -webkit-overflow-scrolling: touch;
  }
  .section-head h2 {
    margin-bottom: 0.35rem;
    font-size: var(--text-lg);
  }
  .section-head h2 a {
    color: var(--text-primary);
    text-decoration: none;
  }
  .section-head h2 a:hover {
    color: var(--accent);
  }
  .section-head p {
    margin: 0 0 0.75rem;
    color: rgb(var(--gray));
    font-size: var(--text-sm);
  }
  :global(.gh-contribute .react-activity-calendar__count) {
    color: rgb(var(--black));
  }
  :global(.gh-contribute article.react-activity-calendar) {
    width: max-content !important;
    max-width: none !important;
    min-width: 100%;
  }
  :global(.gh-contribute .react-activity-calendar svg) {
    display: block;
    width: auto;
    max-width: none;
    height: auto;
  }
  :global(.gh-contribute .react-activity-calendar__legend-colors rect) {
    rx: var(--radius-ui);
  }
  :global(.gh-contribute .react-activity-calendar__scroll-container) {
    width: max-content;
    max-width: none !important;
    overflow-x: visible !important;
    overflow-y: hidden !important;
  }
</style>
