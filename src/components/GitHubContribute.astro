---
import { GH_CONTRIBUTE } from "../consts";
import { fetchGitHubContributions } from "../utils/githubContributions";
import GitHubCalendar from "./GitHubCalendar.astro";

let contributionData = null;

try {
  contributionData = await fetchGitHubContributions(GH_CONTRIBUTE.username);
} catch (error) {
  const message = error instanceof Error ? error.message : String(error);
  console.warn(`[GitHub contributions] ${message}`);
}
---

<section class="gh-contribute">
  <div class="section-head">
    <h2><a href={GH_CONTRIBUTE.profileUrl} target="_blank" rel="noopener noreferrer">{GH_CONTRIBUTE.title}</a></h2>
    <p>{GH_CONTRIBUTE.description}</p>
  </div>
  {
    contributionData ? (
      <GitHubCalendar {...contributionData} />
    ) : (
      <p class="calendar-error">{GH_CONTRIBUTE.errorMessage}</p>
    )
  }
</section>

<style>
  .gh-contribute {
    margin-top: 0;
    width: 100%;
    min-width: 0;
  }
  .section-head h2 {
    margin-bottom: 0.35rem;
    font-size: var(--text-lg);
  }
  .section-head h2 a {
    color: var(--text-primary);
    text-decoration: none;
  }
  .section-head h2 a:hover {
    color: var(--accent);
  }
  .section-head p {
    margin: 0 0 0.75rem;
    color: rgb(var(--gray));
    font-size: var(--text-sm);
  }
  .calendar-error {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
</style>
