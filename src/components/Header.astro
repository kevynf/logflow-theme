---
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import SocialIcon from './SocialIcon.astro';
---

<div class="header-placeholder"></div>
<header id="site-header">
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/friends">Friends</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<div id="nav-indicator"></div>
		</div>
		<div class="actions">
			<div class="social-links">
				{
					SOCIAL_LINKS.map((link) => (
						<a href={link.href} target="_blank" rel="noopener noreferrer">
							<span class="sr-only">{link.label}</span>
							<SocialIcon icon={link.icon} />
						</a>
					))
				}
			</div>
			<ThemeToggle />
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0 auto;
		padding: 0.5em 1em;
		background: transparent;
		backdrop-filter: blur(0px);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0), 0 0 0 1px rgba(255, 255, 255, 0) inset;
		border: 1px solid rgba(255, 255, 255, 0);
		position: fixed;
		top: 0.5rem;
		left: 0;
		right: 0;
		z-index: 100;
		transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
		width: 100%;
		max-width: 1000px;
		box-sizing: border-box;
		border-radius: 0;
	}

	.header-placeholder {
		height: 3.5em; /* Header height + top margin */
	}

	header.scrolled {
		top: 0.5rem;
		width: calc(100% - 2em);
		max-width: 768px;
		border-radius: 16px;
		background: var(--background-header);
		backdrop-filter: blur(12px);
		border: 1px solid var(--glass-border);
		box-shadow: 0 4px 20px var(--glass-shadow), 0 0 0 1px var(--glow-color) inset;
		padding: 0.25em 1.5em;
	}

	:global(.dark) header.scrolled {
		background: var(--background-header);
		box-shadow: 0 4px 20px var(--glass-shadow), 0 0 0 1px var(--glow-color) inset;
	}

	@media (max-width: 760px) {
		header.scrolled {
			max-width: calc(100% - 2em);
		}
	}

	h2 {
		margin: 0;
		margin-right: auto;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		max-width: 1100px;
		margin: 0 auto;
	}
	nav a {
		padding: 0.25em 0.8em;
		color: var(--black);
		border-radius: 999px;
		text-decoration: none;
		transition: color 0.2s ease;
		position: relative;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: center;
		line-height: 1;
		height: 28px;
		box-sizing: border-box;
	}
	nav a:hover {
		color: var(--accent);
	}
	.internal-links {
		display: flex;
		align-items: center;
		margin-right: 1em;
		position: relative;
	}
	#nav-indicator {
		position: absolute;
		left: 0;
		top: 0;
		border-radius: 999px;
		background-color: rgba(var(--gray), 0.15);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border: 1px solid rgba(var(--gray), 0.2);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
		transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
		z-index: 1;
		pointer-events: none;
		opacity: 0;
	}
	.internal-links a {
		font-size: 0.85em;
	}
	nav a.active {
		color: var(--accent);
	}
	nav a.active:hover {
		color: var(--accent);
	}
	.actions {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	.social-links {
		display: flex;
		gap: 0.5em;
	}
	.social-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		padding: 0;
		border-bottom: none;
		border-radius: 50%;
	}
	.social-links a svg {
		width: 20px;
		height: 20px;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>

<script>
	const header = document.querySelector('#site-header');
	const handleScroll = () => {
		if (window.scrollY > 50) {
			header?.classList.add('scrolled');
		} else {
			header?.classList.remove('scrolled');
		}
	};

	window.addEventListener('scroll', handleScroll);

	const linksContainer = document.querySelector('.internal-links');
	const links = linksContainer?.querySelectorAll('a');
	const indicator = document.getElementById('nav-indicator');

	if (linksContainer && links && indicator) {
		const updateIndicator = (el: HTMLElement) => {
			const paddingX = 6;
			const paddingY = 4;
			
			// Get dimensions
			const containerHeight = linksContainer.clientHeight;
			const elementHeight = el.offsetHeight;
			const targetHeight = elementHeight - paddingY;
			
			// Calculate vertical center position
			const verticalCenter = (containerHeight - targetHeight) / 2;
			
			indicator.style.width = `${el.offsetWidth - paddingX}px`;
			indicator.style.height = `${targetHeight}px`;
			indicator.style.transform = `translate(${el.offsetLeft + (paddingX / 2)}px, ${verticalCenter}px)`;
			indicator.style.opacity = '1';
		};

		const resetIndicator = () => {
			const activeLink = linksContainer.querySelector('.active') as HTMLElement;
			if (activeLink) {
				updateIndicator(activeLink);
			} else {
				indicator.style.opacity = '0';
			}
		};

		// Initialize
		// Use requestAnimationFrame to ensure layout is ready
		requestAnimationFrame(() => {
			resetIndicator();
			// Re-calculate on window resize
			window.addEventListener('resize', resetIndicator);
		});

		// Add event listeners
		links.forEach(link => {
			link.addEventListener('mouseenter', (e) => {
				updateIndicator(e.currentTarget as HTMLElement);
			});
		});

		linksContainer.addEventListener('mouseleave', resetIndicator);
	}
</script>
