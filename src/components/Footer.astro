---
import { COPYRIGHT_NAME, SOCIAL_LINKS } from "../consts";
import SocialIcon from "./SocialIcon.astro";
const year = new Date().getFullYear();
---
<footer class="site-footer"><div class="footer-inner"><p>© {year} {COPYRIGHT_NAME} · 使用 Astro 构建</p><div class="social-links">{SOCIAL_LINKS.map((link) => <a href={link.href} target="_blank" rel="noopener noreferrer"><span class="sr-only">{link.label}</span><SocialIcon icon={link.icon} /></a>)}</div></div></footer>
<style>
  .site-footer { width:var(--page-max-width); max-width:calc(100% - 2rem); margin:0 auto; }
  .footer-inner { display:flex; min-height:3.5rem; align-items:center; justify-content:space-between; gap:1rem; color:var(--text-muted); }
  p { margin:0; font-size:var(--text-xs); } .social-links { display:flex; gap:.25rem; } .social-links a { display:grid; width:1.8rem; height:1.8rem; place-items:center; color:var(--text-muted); } .social-links a:hover { color:var(--accent); }
  @media (max-width:480px) { .site-footer { max-width:calc(100% - 1.5rem); } }
</style>
