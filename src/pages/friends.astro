---
import CommentSection from "../components/CommentSection.astro"; import PageHeader from "../components/PageHeader.astro"; import { FRIEND_LINKS, HOME, PAGE_COPY, SITE_TITLE } from "../consts"; import SiteLayout from "../layouts/SiteLayout.astro";
import { withBase } from "../utils/withBase";
const siteUrl = new URL(import.meta.env.BASE_URL, Astro.site).href.replace(/\/$/, "");
const avatarUrl = new URL(withBase(HOME.avatar.src), Astro.site).href;
const ownFriendLinkText=`Name: ${SITE_TITLE}\nDesc: ${HOME.motto}\nLink: ${siteUrl}\nAvatar: ${avatarUrl}`;
---
<SiteLayout title={`${PAGE_COPY.friends.title} | ${SITE_TITLE}`} description={PAGE_COPY.friends.description}><PageHeader title={PAGE_COPY.friends.title} description={PAGE_COPY.friends.description} descriptionItalic={PAGE_COPY.friends.descriptionItalic} meta={`${FRIEND_LINKS.length} 个`}/><ul class="friends-list">{FRIEND_LINKS.map((link)=><li><a href={link.link??link.url} target="_blank" rel="noopener noreferrer">{link.avatar?<img src={link.avatar} alt="" width="40" height="40" loading="lazy"/>:<span class="friend-avatar">{link.name.slice(0,1)}</span>}<span><strong>{link.name}</strong><small>{link.desc??link.description}</small></span></a></li>)}</ul><section class="exchange-section"><h2>交换友链</h2><pre><code>{ownFriendLinkText}</code></pre></section><CommentSection/></SiteLayout>
