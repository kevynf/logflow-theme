---
import { getCollection } from "astro:content"; import PageHeader from "../../components/PageHeader.astro"; import PostList from "../../components/PostList.astro"; import { PAGE_COPY, SITE_TITLE } from "../../consts"; import SiteLayout from "../../layouts/SiteLayout.astro";
const posts=(await getCollection("blog")).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf()); const map=new Map<number,typeof posts>(); for(const post of posts){const year=post.data.pubDate.getFullYear();map.set(year,[...(map.get(year)??[]),post]);} const groups=Array.from(map.entries()).sort((a,b)=>b[0]-a[0]);
---
<SiteLayout title={`${PAGE_COPY.years.title} | ${SITE_TITLE}`} description={PAGE_COPY.years.description}><PageHeader title={PAGE_COPY.years.title} description={PAGE_COPY.years.description} descriptionItalic={PAGE_COPY.years.descriptionItalic} meta={`${posts.length} 篇`}/><div class="years">{groups.map(([year,items])=><section class="year-group"><h2>{year}<small>{items.length} 篇</small></h2><PostList posts={items} showDescription={false}/></section>)}</div></SiteLayout>
