---
import { getCollection } from "astro:content";
import PageHeader from "../../../components/PageHeader.astro";
import PostList from "../../../components/PostList.astro";
import { PAGE_COPY, SITE_TITLE } from "../../../consts";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { taxonomySlug } from "../../../utils/content";
export async function getStaticPaths() { const posts = await getCollection("blog"); const names = new Set(posts.flatMap((post) => post.data.collection ? [post.data.collection] : [])); return Array.from(names).map((name) => ({ params: { slug: taxonomySlug(name) }, props: { collectionName: name } })); }
const { collectionName } = Astro.props; const posts = (await getCollection("blog")).filter((post) => post.data.collection === collectionName).sort((a,b) => b.data.pubDate.valueOf()-a.data.pubDate.valueOf()); const description = posts.find((post) => post.data.collectionDescription)?.data.collectionDescription ?? PAGE_COPY.collections.description;
---
<SiteLayout title={`${collectionName} | 专题 | ${SITE_TITLE}`} description={description}><PageHeader title={collectionName} description={description} meta={`${posts.length} 篇`} /><PostList posts={posts} showDescription={false} /></SiteLayout>
