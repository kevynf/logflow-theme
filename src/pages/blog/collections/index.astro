---
import { getCollection } from "astro:content"; import PageHeader from "../../../components/PageHeader.astro"; import { PAGE_COPY, SITE_TITLE } from "../../../consts"; import SiteLayout from "../../../layouts/SiteLayout.astro"; import { collectionPath } from "../../../utils/content"; import { withBase } from "../../../utils/withBase";
const posts=await getCollection("blog"); const map=new Map<string,{description:string;count:number}>(); for(const post of posts){if(!post.data.collection)continue;const current=map.get(post.data.collection);const description=post.data.collectionDescription??"";if(current){current.count++;current.description ||= description;}else map.set(post.data.collection,{description,count:1});} const items=Array.from(map.entries()).sort((a,b)=>b[1].count-a[1].count);
---
<SiteLayout title={`${PAGE_COPY.collections.title} | ${SITE_TITLE}`} description={PAGE_COPY.collections.description}><PageHeader title={PAGE_COPY.collections.title} description={PAGE_COPY.collections.description} descriptionItalic={PAGE_COPY.collections.descriptionItalic} meta={`${items.length} 个`}/><ul class="collection-list">{items.map(([name,meta])=><li><a href={withBase(collectionPath(name))}><strong>{name}</strong><span class="collection-list-details"><small>{meta.description}</small><em>{meta.count} 篇 →</em></span></a></li>)}</ul></SiteLayout>
