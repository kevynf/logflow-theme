---
import { getCollection } from "astro:content";
import FormattedDate from "../../../components/FormattedDate.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../../consts";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { withBase } from "../../../utils/withBase";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const tags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      tags.add(tag);
    }
  }
  return Array.from(tags).map((tag) => ({
    params: { slug: tag },
    props: { tagName: tag },
  }));
}

const { tagName } = Astro.props;
const posts = (await getCollection("blog"))
  .filter((post) => (post.data.tags ?? []).includes(tagName))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = `${tagName} | Tags | ${SITE_TITLE}`;
---

<SiteLayout title={pageTitle} description={SITE_DESCRIPTION}>
  <h1>Tag: {tagName}</h1>
  <p class="summary">共 {posts.length} 篇文章</p>
  <ul class="list">
    {
      posts.map((post) => (
        <li>
          <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
          <time datetime={post.data.pubDate.toISOString().slice(0, 10)}>
            <FormattedDate date={post.data.pubDate} />
          </time>
        </li>
      ))
    }
  </ul>
</SiteLayout>

<style>
  h1 {
    margin: 0 0 0.35rem;
    font-size: 1.25rem;
    line-height: 1.2;
  }
  .summary {
    margin: 0 0 1rem;
    color: rgb(var(--gray));
  }
  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--gap-sm);
  }
  .list a {
    text-decoration: none;
    font-weight: 600;
  }
  time {
    margin-left: 0.5rem;
    color: rgb(var(--gray));
  }
  @media (max-width: 720px) {
    .list li {
      display: grid;
      gap: var(--gap-2xs);
    }
    time {
      margin-left: 0;
    }
  }
</style>
