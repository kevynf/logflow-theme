---
import { getCollection } from "astro:content"; import PageHeader from "../../../components/PageHeader.astro"; import { PAGE_COPY, SITE_TITLE } from "../../../consts"; import SiteLayout from "../../../layouts/SiteLayout.astro"; import { tagPath } from "../../../utils/content"; import { withBase } from "../../../utils/withBase";
const posts=await getCollection("blog"); const map=new Map<string,number>(); for(const post of posts) for(const tag of post.data.tags??[]) map.set(tag,(map.get(tag)??0)+1); const tags=Array.from(map.entries()).sort((a,b)=>b[1]-a[1]);
---
<SiteLayout title={`${PAGE_COPY.tags.title} | ${SITE_TITLE}`} description={PAGE_COPY.tags.description}><PageHeader title={PAGE_COPY.tags.title} description={PAGE_COPY.tags.description} descriptionItalic={PAGE_COPY.tags.descriptionItalic} meta={`${tags.length} 个`}/><div class="tag-grid">{tags.map(([tag,count],index)=><a href={withBase(tagPath(tag))}><span class="tag-index">{String(index+1).padStart(2,"0")}</span><strong>{tag}</strong><small>{count} 篇</small></a>)}</div></SiteLayout>
