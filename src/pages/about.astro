---
import { getEntry, render } from "astro:content"; import PageHeader from "../components/PageHeader.astro"; import { PAGE_COPY, SITE_TITLE } from "../consts"; import SiteLayout from "../layouts/SiteLayout.astro";
const entry=await getEntry("about","index"); if(!entry) throw new Error("Missing about content file: src/content/about/index.md"); const {Content}=await render(entry);
---
<SiteLayout title={`${PAGE_COPY.about.title} | ${SITE_TITLE}`} description={PAGE_COPY.about.description}><PageHeader title={PAGE_COPY.about.title} description={PAGE_COPY.about.description} descriptionItalic={PAGE_COPY.about.descriptionItalic}/><article class="reading-column content-prose"><Content/></article></SiteLayout>
