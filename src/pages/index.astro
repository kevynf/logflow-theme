---
import { getCollection, getEntry } from "astro:content";
import GitHubContribute from "../components/GitHubContribute.astro";
import { HOME_PROFILE, SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import SiteLayout from "../layouts/SiteLayout.astro";
import { withBase } from "../utils/withBase";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts = allPosts.slice(0, HOME_PROFILE.recentPostsLimit);
const tagMap = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}
const tags = Array.from(tagMap.entries())
  .sort((a, b) => b[1] - a[1])
  .map(([name, count]) => ({ name, count }));
const maxTagCount = Math.max(1, ...tags.map((item) => item.count));

const aboutEntry = await getEntry("about", "index");
const aboutRaw = aboutEntry?.body ?? "";
const paragraphs = aboutRaw
  .split(/\r?\n\r?\n/)
  .map((item) => item.trim())
  .filter(
    (item) =>
      item.length > 0 && !item.startsWith("#") && !item.startsWith("---"),
  );
const firstParagraph = (paragraphs[0] ?? "")
  .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
  .replace(/[*_`>#-]/g, "");
const aboutExcerpt =
  firstParagraph.length > HOME_PROFILE.aboutExcerptLength
    ? `${firstParagraph.slice(0, HOME_PROFILE.aboutExcerptLength)}...`
    : firstParagraph;
const profileStyle = `--profile-name-size: ${HOME_PROFILE.nicknameFontSize ?? "1.45rem"}; --profile-tagline-size: ${HOME_PROFILE.taglineFontSize ?? "1em"};`;
const contentStyle = `--home-posts-column: ${HOME_PROFILE.homePostsColumnRatio ?? "0.82fr"}; --home-tags-min: ${HOME_PROFILE.homeTagsMinWidth ?? "260px"};`;
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Fragment slot="head">
    <style>
      .home-profile {
        margin-top: 0;
      }
      .home-about {
        margin-top: 0;
      }
      .home-profile + .home-about {
        margin-top: calc(var(--section-gap-y) * 0.75);
        padding-top: calc(var(--section-gap-y) * 0.75);
      }
      .avatar-wrap {
        width: 100%;
        height: var(--profile-avatar-size);
        border: 2px solid rgba(var(--gray), 0.25);
        border-radius: 8px;
        overflow: hidden;
      }
      .profile-intro {
        --profile-avatar-size: 132px;
        --profile-side-gap: clamp(0.75rem, 2vw, 1.1rem);
        display: grid;
        grid-template-columns: var(--profile-avatar-size) minmax(0, 1fr);
        column-gap: var(--profile-side-gap);
        align-items: stretch;
        max-width: 560px;
      }
      .profile-meta {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: var(--profile-avatar-size);
        text-align: left;
        margin: 0;
        min-width: 0;
      }
      .profile-tagline {
        margin: 0.3rem 0 0;
        font-size: var(--profile-tagline-size);
        line-height: 1.65;
        color: rgb(var(--gray));
        overflow-wrap: anywhere;
        white-space: normal;
      }
      .profile-tagline.is-italic {
        font-style: italic;
        display: inline-block;
        transform: skewX(-8deg);
        transform-origin: left center;
      }
      .avatar-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 0;
      }
      .home-about {
        padding: 0;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
      }
      .about-title,
      .recent-posts h2,
      .home-tags h2 {
        margin: 0 0 0.35rem;
        font-size: 1.25rem;
        line-height: 1.2;
        color: rgb(var(--black));
      }
      .profile-name {
        margin: 0 0 0.35rem;
        font-size: var(--profile-name-size);
        line-height: 1.2;
        color: rgb(var(--black));
      }
      .home-about p {
        margin: 0 0 0.75rem;
        color: rgb(var(--gray));
        font-size: 1em;
      }
      .home-about a {
        text-decoration: none;
        font-weight: 600;
        font-size: 1em;
      }
      .home-content {
        display: grid;
        grid-template-columns: minmax(0, var(--home-posts-column)) minmax(
            var(--home-tags-min),
            1fr
          );
        gap: var(--section-gap-x);
        align-items: start;
      }
      .recent-posts {
        max-width: 520px;
      }
      .home-tags {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        border-left: var(--section-divider-width) solid
          var(--section-divider-color);
        padding-left: var(--gap-xl);
        width: 100%;
      }
      .home-tags h2 {
        width: min(100%, 344px);
        margin-right: auto;
      }
      .recent-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: var(--gap-lg);
      }
      .recent-list li {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: baseline;
        column-gap: var(--gap-lg-plus);
      }
      .recent-list a {
        text-decoration: none;
        font-weight: 600;
        font-size: 1em;
        color: var(--accent);
        min-width: 0;
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transition: color 0.2s ease;
      }
      .recent-list a:hover,
      .recent-list a:focus-visible {
        color: var(--accent);
      }
      .recent-list time {
        font-size: 0.92em;
        color: rgb(var(--gray));
        white-space: nowrap;
      }
      .tags-sphere {
        --tag-sphere-safe-inset: 10px;
        position: relative;
        width: min(100%, 344px);
        aspect-ratio: 1 / 1;
        height: auto;
        margin: 0 auto 0 0;
        perspective: 1100px;
        perspective-origin: 50% 50%;
        overflow: hidden;
      }
      .tags-sphere .tag-node {
        position: absolute;
        top: 0;
        left: 0;
        text-decoration: none;
        font-size: var(--tag-cloud-size);
        line-height: 1.2;
        display: inline-block;
        transform-origin: center center;
        will-change: transform, opacity;
        white-space: nowrap;
      }
      .tags-empty {
        margin: 0;
        font-size: 0.95em;
        color: rgb(var(--gray));
        text-align: center;
      }
      .home-contribute {
        min-width: 0;
        width: 100%;
      }
      @media (max-width: 720px) {
        .profile-intro {
          --profile-avatar-size: 96px;
          --profile-side-gap: var(--gap-md);
          max-width: none;
        }
        .home-content {
          grid-template-columns: 1fr;
        }
        .recent-list {
          display: grid;
          gap: var(--gap-lg);
        }
        .home-tags {
          border-left: 0;
          border-top: var(--section-divider-width) solid
            var(--section-divider-color);
          align-items: flex-start;
          justify-content: flex-start;
          padding-left: 0;
          padding-top: var(--gap-xl);
          height: auto;
        }
        .tags-sphere {
          width: min(100%, 296px);
          margin: 0;
        }
        .home-tags h2 {
          width: auto;
        }
      }

      @media (max-width: 430px) {
        .profile-intro {
          --profile-avatar-size: 80px;
          --profile-side-gap: var(--gap-sm-plus);
        }
        .profile-name {
          margin-bottom: 0.2rem;
          font-size: clamp(1.1rem, 5vw, var(--profile-name-size));
        }
        .profile-tagline {
          margin-top: 0.18rem;
          font-size: clamp(0.84rem, 3.6vw, var(--profile-tagline-size));
          line-height: 1.5;
        }
      }
    </style>
  </Fragment>
  <section class="home-profile" style={profileStyle}>
    <div class="profile-intro">
      <div class="avatar-wrap">
        <img
          src={HOME_PROFILE.avatarSrc}
          alt={HOME_PROFILE.avatarAlt}
          loading="lazy"
        />
      </div>
      <div class="profile-meta">
        <h2 class="profile-name">{HOME_PROFILE.nickname}</h2>
        <p
          class:list={[
            "profile-tagline",
            { "is-italic": HOME_PROFILE.taglineItalic },
          ]}
        >
          {HOME_PROFILE.tagline}
        </p>
      </div>
    </div>
  </section>

  <section class="home-about">
    <h2 class="about-title">About</h2>
    <p>{aboutExcerpt}</p>
    <a href={withBase("/about")}>Read full introduction</a>
  </section>

  <section class="home-content" style={contentStyle}>
    <section class="recent-posts">
      <h2>Posts</h2>
      <ul class="recent-list">
        {
          posts.map((post) => (
            <li>
              <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
              <time datetime={post.data.pubDate.toISOString().slice(0, 10)}>
                {post.data.pubDate.toISOString().slice(5, 10)}
              </time>
            </li>
          ))
        }
      </ul>
    </section>
    <section class="home-tags">
      <h2>Tags</h2>
      {
        tags.length === 0 ? (
          <p class="tags-empty">No tags</p>
        ) : (
          <div class="tags-sphere" data-tag-sphere>
            {tags.map((tag) => (
              <a
                class="tag-node"
                style={`--tag-cloud-size: ${0.88 + (tag.count / maxTagCount) * 0.42}em;`}
                href={withBase(`/blog/tags/${encodeURIComponent(tag.name)}/`)}
              >
                {tag.name}
              </a>
            ))}
          </div>
        )
      }
    </section>
  </section>

  <section class="home-contribute">
    <GitHubContribute />
  </section>
</SiteLayout>

<script is:inline>
  const homeContent = document.querySelector(".home-content");
  const recentPostsSection = homeContent?.querySelector(".recent-posts");
  const homeTagsSection = homeContent?.querySelector(".home-tags");
  const homeColumnsMedia = window.matchMedia("(min-width: 721px)");

  const syncHomeSectionHeights = () => {
    if (!recentPostsSection || !homeTagsSection) {
      return;
    }
    homeTagsSection.style.height = "auto";
    if (!homeColumnsMedia.matches) {
      return;
    }
    homeTagsSection.style.height = `${recentPostsSection.offsetHeight}px`;
  };

  syncHomeSectionHeights();
  window.addEventListener("load", syncHomeSectionHeights);
  window.addEventListener("resize", syncHomeSectionHeights);
  const homeSectionResizeObserver =
    recentPostsSection && homeTagsSection
      ? new ResizeObserver(() => syncHomeSectionHeights())
      : null;
  homeSectionResizeObserver?.observe(recentPostsSection);

  const spheres = document.querySelectorAll("[data-tag-sphere]");
  for (const sphere of spheres) {
    const nodes = Array.from(sphere.querySelectorAll(".tag-node"));
    if (nodes.length === 0) continue;
    const state = [];
    const nodeMetrics = nodes.map((node) => ({
      width: node.offsetWidth,
      height: node.offsetHeight,
    }));
    const size = Math.min(sphere.clientWidth, sphere.clientHeight);
    const sphereStyle = getComputedStyle(sphere);
    const safeInset =
      Number.parseFloat(
        sphereStyle.getPropertyValue("--tag-sphere-safe-inset") || "10",
      ) || 10;
    const usableSize = Math.max(0, size - safeInset * 2);
    const radius = usableSize * 0.345;
    const projectionDistance = size * 1.75;
    let vx = 0.0022;
    let vy = 0.0016;
    let tx = vx;
    let ty = vy;
    const cx = sphere.clientWidth / 2;
    const cy = sphere.clientHeight / 2;
    for (let i = 0; i < nodes.length; i++) {
      const y = 1 - (i / Math.max(nodes.length - 1, 1)) * 2;
      const r = Math.sqrt(1 - y * y);
      const phi = Math.PI * (3 - Math.sqrt(5)) * i;
      state.push({
        x: Math.cos(phi) * r * radius,
        y: y * radius,
        z: Math.sin(phi) * r * radius,
      });
    }
    const rotateY = (p, a) => {
      const c = Math.cos(a);
      const s = Math.sin(a);
      const x = p.x * c - p.z * s;
      const z = p.x * s + p.z * c;
      p.x = x;
      p.z = z;
    };
    const rotateX = (p, a) => {
      const c = Math.cos(a);
      const s = Math.sin(a);
      const y = p.y * c - p.z * s;
      const z = p.y * s + p.z * c;
      p.y = y;
      p.z = z;
    };
    const measureNodes = () => {
      for (let i = 0; i < nodes.length; i++) {
        nodeMetrics[i].width = nodes[i].offsetWidth;
        nodeMetrics[i].height = nodes[i].offsetHeight;
      }
    };
    const render = () => {
      vx += (tx - vx) * 0.08;
      vy += (ty - vy) * 0.08;
      const projectedNodes = [];
      let totalX = 0;
      let totalY = 0;
      for (let i = 0; i < nodes.length; i++) {
        const p = state[i];
        rotateY(p, vx);
        rotateX(p, vy);
        const depth = (p.z + radius) / (radius * 2);
        const perspectiveScale =
          projectionDistance / (projectionDistance - p.z);
        const projectedX = p.x * perspectiveScale;
        const projectedY = p.y * perspectiveScale;
        const scale = 0.62 + depth * 0.68;
        const opacity = 0.32 + depth * 0.62;
        const finalScale = scale * perspectiveScale;
        const nodeX = cx + projectedX;
        const nodeY = cy + projectedY;
        totalX += nodeX;
        totalY += nodeY;
        projectedNodes.push({
          nodeX,
          nodeY,
          finalScale,
          opacity,
          zIndex: Math.round(depth * 100),
        });
      }
      const offsetX = cx - totalX / nodes.length;
      const offsetY = cy - totalY / nodes.length;
      for (let i = 0; i < nodes.length; i++) {
        const projected = projectedNodes[i];
        nodes[i].style.transform =
          `translate3d(${projected.nodeX + offsetX}px, ${projected.nodeY + offsetY}px, 0) translate(-50%, -50%) scale(${projected.finalScale})`;
        nodes[i].style.opacity = String(projected.opacity);
        nodes[i].style.zIndex = String(projected.zIndex);
      }
      requestAnimationFrame(render);
    };
    sphere.addEventListener("pointermove", (e) => {
      const rect = sphere.getBoundingClientRect();
      const nx = (e.clientX - rect.left) / rect.width - 0.5;
      const ny = (e.clientY - rect.top) / rect.height - 0.5;
      tx = nx * 0.018;
      ty = ny * 0.018;
    });
    sphere.addEventListener("pointerleave", () => {
      tx = 0.0022;
      ty = 0.0016;
    });
    measureNodes();
    window.addEventListener("resize", measureNodes);
    render();
  }
</script>
